<Window x:Class="WarehouseApp.Views.InvoiceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Накладная" Height="500" Width="800"
        WindowStartupLocation="CenterOwner"
        Background="#EEF1F5">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Тип накладной:" VerticalAlignment="Center" Margin="0,0,10,0" />
            <RadioButton x:Name="IncomingRadio" Content="Входящая" IsChecked="True" Margin="0,0,10,0"/>
            <RadioButton x:Name="OutgoingRadio" Content="Исходящая"/>
        </StackPanel>

        <DataGrid x:Name="ProductsGrid" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False" SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Наименование" Binding="{Binding Name}" IsReadOnly="True" Width="2*"/>
                <DataGridTextColumn Header="Категория" Binding="{Binding Category}" IsReadOnly="True" Width="*"/>
                <DataGridTextColumn Header="Производитель" Binding="{Binding Manufacturer}" IsReadOnly="True" Width="*"/>
                <DataGridTextColumn Header="Поставщик" Binding="{Binding Supplier}" IsReadOnly="True" Width="*"/>
                <DataGridTextColumn Header="Цена" Binding="{Binding Price}" IsReadOnly="True" Width="90"/>
                <DataGridTextColumn Header="На складе" Binding="{Binding StockQuantity}" IsReadOnly="True" Width="80"/>
                <DataGridTextColumn Header="Количество" Binding="{Binding QuantityToMove}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Применить" Width="120" Margin="5" Click="Apply_Click"/>
            <Button Content="Отмена" Width="120" Margin="5" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>