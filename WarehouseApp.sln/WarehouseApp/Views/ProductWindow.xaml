<Window x:Class="WarehouseApp.Views.ProductWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Товар"
        Height="470"
        Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#EEF1F5">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="35"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="35"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="35"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="35"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="35"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="35"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="35"/>
                <RowDefinition Height="50"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Наименование"/>
            <TextBox x:Name="NameBox"
                     Grid.Row="1"
                     Margin="0,5,0,10"/>

            <TextBlock Grid.Row="2"
                       Text="Категория"/>
            <TextBox x:Name="CategoryBox"
                     Grid.Row="3"
                     Margin="0,5,0,10"/>

            <TextBlock Grid.Row="4"
                       Text="Производитель"/>
            <TextBox x:Name="ManufacturerBox"
                     Grid.Row="5"
                     Margin="0,5,0,10"/>

            <TextBlock Grid.Row="6"
                       Text="Поставщик"/>
            <TextBox x:Name="SupplierBox"
                     Grid.Row="7"
                     Margin="0,5,0,10"/>

            <TextBlock Grid.Row="8"
                       Text="Цена"/>
            <TextBox x:Name="PriceBox"
                     Grid.Row="9"
                     Margin="0,5,0,10"/>

            <TextBlock Grid.Row="10"
                       Text="Остаток"/>
            <TextBox x:Name="StockBox"
                     Grid.Row="11"
                     Margin="0,5,0,10"/>

            <TextBlock Grid.Row="12"
                       Text="Скидка %"/>
            <TextBox x:Name="DiscountBox"
                     Grid.Row="13"
                     Margin="0,5,0,10"/>

            <StackPanel Grid.Row="14"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="Сохранить"
                        Width="95"
                        Margin="0,0,8,0"
                        Click="Save_Click"/>

                <Button Content="Отмена"
                        Width="80"
                        Click="Cancel_Click"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Window>


