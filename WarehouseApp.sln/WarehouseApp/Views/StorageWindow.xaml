<Window x:Class="WarehouseApp.Views.StorageWindow"

        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

        Title="Склады и товары"

        Height="620"

        Width="1050"

        WindowStartupLocation="CenterOwner"

        Background="#EEF1F5">

    <Grid>

        <Grid.RowDefinitions>

            <RowDefinition Height="42"/>

            <RowDefinition Height="*"/>

            <RowDefinition Height="32"/>

        </Grid.RowDefinitions>

       

        <Border Grid.Row="0" Background="#26384D">

            <DockPanel>

                <TextBlock x:Name="OrganizationText"

                           Text="Организация"

                           Foreground="White"

                           FontSize="16"

                           FontWeight="SemiBold"

                           VerticalAlignment="Center"

                           Margin="14,0"/>

                <Menu DockPanel.Dock="Right"

                      HorizontalAlignment="Right"

                      Background="#26384D"

                      Foreground="White">

                    <MenuItem Header="Файл"/>

                    <MenuItem Header="Склады">

                        <MenuItem Header="Новый склад" Click="AddWarehouse_Click"/>

                        <MenuItem Header="Изменить склад" Click="EditWarehouse_Click"/>

                        <MenuItem Header="Удалить склад" Click="DeleteWarehouse_Click"/>

                    </MenuItem>

                    <MenuItem Header="Товары">

                        <MenuItem Header="Добавить товар" Click="AddProduct_Click"/>

                        <MenuItem Header="Изменить товар" Click="EditProduct_Click"/>

                        <MenuItem Header="Удалить товар" Click="DeleteProduct_Click"/>

                    </MenuItem>

                    <MenuItem Header="Справочники"/>

                    <MenuItem Header="Импорт" Click="ImportProducts_Click"/>

                    <MenuItem Header="Накладные" Click="OpenInvoiceWindow_Click"/>

                </Menu>

            </DockPanel>

        </Border>
        <Grid Grid.Row="1" Margin="12">

            <Grid.ColumnDefinitions>

                <ColumnDefinition Width="280"/>

                <ColumnDefinition Width="12"/>

                <ColumnDefinition Width="*"/>

            </Grid.ColumnDefinitions>


            <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="12" BorderBrush="#D5DAE0" BorderThickness="1">

                <Grid>

                    <Grid.RowDefinitions>

                        <RowDefinition Height="Auto"/>

                        <RowDefinition Height="*"/>

                        <RowDefinition Height="42"/>

                    </Grid.RowDefinitions>

                    <TextBlock Text="Склады" FontSize="18" FontWeight="Bold" Foreground="#26384D"/>

                    <ListBox x:Name="WarehousesList" Grid.Row="1" Margin="0,10,0,10" DisplayMemberPath="Name" SelectionChanged="WarehousesList_SelectionChanged"/>

                    <StackPanel Grid.Row="2" Orientation="Horizontal">

                        <Button Content="Новый" Width="76" Margin="0,0,6,0" Click="AddWarehouse_Click"/>

                        <Button Content="Изменить" Width="86" Margin="0,0,6,0" Click="EditWarehouse_Click"/>

                        <Button Content="Удалить" Width="76" Click="DeleteWarehouse_Click"/>

                    </StackPanel>

                </Grid>

            </Border>


            <Border Grid.Column="2" Background="White" CornerRadius="8" Padding="12" BorderBrush="#D5DAE0" BorderThickness="1">

                <Grid>

                    <Grid.RowDefinitions>

                        <RowDefinition Height="Auto"/>

                        <RowDefinition Height="*"/>

                        <RowDefinition Height="45"/>

                    </Grid.RowDefinitions>

                    <DockPanel>

                        <TextBlock Text="Товары на складе" FontSize="20" FontWeight="Bold" Foreground="#26384D"/>

                        <TextBlock x:Name="CurrentWarehouseText" Foreground="#697586" FontSize="13" HorizontalAlignment="Right" VerticalAlignment="Center"/>

                    </DockPanel>

                    <DataGrid x:Name="ProductsGrid" Grid.Row="1" Margin="0,12,0,10" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single">

                        <DataGrid.Columns>

                            <DataGridTextColumn Header="Наименование" Binding="{Binding Name}" Width="2*"/>

                            <DataGridTextColumn Header="Категория" Binding="{Binding Category}" Width="*"/>

                            <DataGridTextColumn Header="Производитель" Binding="{Binding Manufacturer}" Width="*"/>

                            <DataGridTextColumn Header="Поставщик" Binding="{Binding Supplier}" Width="*"/>

                            <DataGridTextColumn Header="Цена" Binding="{Binding Price}" Width="90"/>

                            <DataGridTextColumn Header="Остаток" Binding="{Binding StockQuantity}" Width="80"/>

                            <DataGridTextColumn Header="Скидка %" Binding="{Binding DiscountPercent}" Width="80"/>

                        </DataGrid.Columns>

                    </DataGrid>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">

                        <Button Content="Добавить товар" Width="120" Margin="0,0,8,0" Click="AddProduct_Click"/>

                        <Button Content="Изменить" Width="95" Margin="0,0,8,0" Click="EditProduct_Click"/>

                        <Button Content="Удалить" Width="95" Click="DeleteProduct_Click"/>

                    </StackPanel>

                </Grid>

            </Border>

        </Grid>

        <Border Grid.Row="2" Background="#DDE3EA">

            <TextBlock x:Name="StatusText" VerticalAlignment="Center" Margin="15,0" Foreground="#26384D" Text="Готово"/>

        </Border>

    </Grid>

</Window>




